<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/alarm_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="32dp"
            android:paddingEnd="24dp"
            android:paddingBottom="152dp">

            <TextView
                android:id="@+id/alarm_title_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/alarm_screen_title"
                android:textColor="@color/black"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/alarm_subtitle_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/alarm_screen_subtitle"
                android:textColor="@color/black"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/alarm_now_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:textColor="@color/black"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/alarm_open_system_button"
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="26dp"
                android:gravity="center"
                android:text="@string/alarm_open_system"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/alarm_create_button"
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/alarm_create_new"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/alarm_timer_10_button"
                    android:layout_width="0dp"
                    android:layout_height="108dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/alarm_timer_10"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/alarm_timer_30_button"
                    android:layout_width="0dp"
                    android:layout_height="108dp"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/alarm_timer_30"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <TextView
        android:id="@+id/close_alarm_button"
        android:layout_width="260dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_close_button"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="@string/alarm_back"
        android:textColor="@color/white"
        android:textSize="34sp"
        android:textStyle="bold" />

    <include layout="@layout/view_volume_overlay" />

</FrameLayout>
