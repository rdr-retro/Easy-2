<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/food_scanner_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="32dp"
        android:paddingEnd="24dp"
        android:paddingBottom="144dp">

        <TextView
            android:id="@+id/food_scanner_title_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/food_scanner_screen_title"
            android:textColor="@color/black"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/food_scanner_intro_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/food_scanner_intro"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_scanner_preview"
            android:clipToOutline="true"
            android:elevation="8dp">

            <androidx.camera.view.PreviewView
                android:id="@+id/food_scanner_preview_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <View
                android:layout_width="220dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_scanner_focus_frame" />

            <TextView
                android:id="@+id/food_scanner_preview_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="18dp"
                android:background="#66000000"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingTop="10dp"
                android:paddingEnd="16dp"
                android:paddingBottom="10dp"
                android:text="@string/food_scanner_preview_hint"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

        </FrameLayout>

        <TextView
            android:id="@+id/food_scanner_scan_button"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_save_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/food_scanner_scan_now"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/food_scanner_result_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_weather_panel"
            android:elevation="6dp"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="24dp"
            android:paddingEnd="22dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/food_scanner_result_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/food_scanner_result_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/launcher_green"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/food_scanner_result_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/food_scanner_result_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/food_scanner_close_button"
        android:layout_width="260dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_close_button"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="@string/utilities_close_button"
        android:textColor="@color/white"
        android:textSize="34sp"
        android:textStyle="bold" />

    <include layout="@layout/view_volume_overlay" />

</FrameLayout>
