<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/top_panel"
            android:layout_width="match_parent"
            android:layout_height="157dp"
            android:layout_weight="4"
            android:background="@color/launcher_green"
            android:paddingTop="0dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:id="@+id/top_content_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/status_block"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <LinearLayout
                        android:id="@+id/status_row"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextClock
                            android:id="@+id/clock_view"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:format12Hour="hh:mm"
                            android:format24Hour="HH:mm"
                            android:textColor="@color/white"
                            android:textSize="36sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.rdr.easy2.BatteryIconView
                                android:id="@+id/battery_icon"
                                android:layout_width="53dp"
                                android:layout_height="36dp"
                                android:contentDescription="@null" />

                            <TextView
                                android:id="@+id/battery_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/battery_unknown"
                                android:textColor="@color/white"
                                android:textSize="30sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/charging_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/battery_charging"
                                android:textColor="@color/white"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:visibility="gone" />

                        </LinearLayout>

                    </LinearLayout>

                    <TextClock
                        android:id="@+id/date_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:format12Hour="EEEE, d MMMM"
                        android:format24Hour="EEEE, d MMMM"
                        android:textAlignment="center"
                        android:textColor="@color/white"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/name_view"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/launcher_name"
                            android:textColor="@color/white"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/age_view"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="@string/launcher_age"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:id="@+id/header_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginEnd="24dp"
                    android:alpha="0.6"
                    android:background="@color/white" />

                <HorizontalScrollView
                    android:id="@+id/shortcuts_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fillViewport="false"
                    android:overScrollMode="never"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/shortcuts_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal" />

                        <ImageView
                            android:id="@+id/medical_info_button"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginStart="16dp"
                            android:background="@drawable/bg_medical_quick_action"
                            android:contentDescription="@string/medical_info_content_description"
                            android:padding="16dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_medical_card" />

                        <TextView
                            android:id="@+id/add_app_button"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginStart="16dp"
                            android:background="@drawable/bg_quick_action"
                            android:gravity="center"
                            android:text="@string/add_shortcut_symbol"
                            android:textColor="@color/white"
                            android:textSize="38sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/settings_button"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_quick_action"
                            android:contentDescription="@string/settings_content_description"
                            android:gravity="center"
                            android:text="@string/settings_symbol"
                            android:textColor="@color/white"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/sos_button"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_sos_quick_action"
                            android:contentDescription="@string/sos_content_description"
                            android:gravity="center"
                            android:text="@string/sos_label"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </HorizontalScrollView>

                <LinearLayout
                    android:id="@+id/weather_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="24dp"
                    android:background="@drawable/bg_weather_panel"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/weather_line"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/weather_loading"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/phone_apps_button"
                        android:layout_width="wrap_content"
                        android:layout_height="45dp"
                        android:background="@drawable/bg_weather_panel"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingStart="20dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="10dp"
                        android:text="@string/phone_apps_button_label"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/utilities_button"
                        android:layout_width="wrap_content"
                        android:layout_height="45dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_weather_panel"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingStart="20dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="10dp"
                        android:text="@string/utilities_button_label"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <FrameLayout
            android:id="@+id/bottom_panel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="6"
            android:background="@color/white">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/contacts_recycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingStart="12dp"
                android:paddingTop="20dp"
                android:paddingEnd="12dp"
                android:paddingBottom="24dp" />

            <TextView
                android:id="@+id/contacts_empty_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:text="@string/contacts_loading"
                android:textAlignment="center"
                android:textColor="@color/launcher_green"
                android:textSize="24sp"
                android:textStyle="bold" />

        </FrameLayout>

    </LinearLayout>

    <include layout="@layout/view_volume_overlay" />

</FrameLayout>
