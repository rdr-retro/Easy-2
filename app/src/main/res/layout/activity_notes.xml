<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notes_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="26dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <FrameLayout
            android:id="@+id/notes_top_bar"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:background="@drawable/bg_weather_panel"
            android:elevation="6dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/notes_add_button"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center_vertical|start"
                android:clickable="true"
                android:contentDescription="@string/notes_add_description"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/notes_add_button"
                android:textColor="@color/white"
                android:textSize="38sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/notes_title_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/notes_screen_title"
                android:textColor="@color/black"
                android:textSize="34sp"
                android:textStyle="bold" />

        </FrameLayout>

        <ScrollView
            android:id="@+id/notes_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="20dp">

                <TextView
                    android:id="@+id/notes_empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingTop="28dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="28dp"
                    android:text="@string/notes_empty_state"
                    android:textColor="@color/black"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/notes_saved_note"
                    android:layout_width="260dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_note_paper"
                    android:clickable="true"
                    android:elevation="10dp"
                    android:ellipsize="end"
                    android:focusable="true"
                    android:gravity="top|start"
                    android:lineSpacingExtra="6dp"
                    android:maxLines="5"
                    android:minHeight="210dp"
                    android:paddingStart="18dp"
                    android:paddingTop="20dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="20dp"
                    android:textColor="#FF4A3A14"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/notes_delete_button"
                    android:layout_width="220dp"
                    android:layout_height="84dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_close_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/notes_delete"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/notes_editor_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/notes_editor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_note_paper"
                        android:elevation="10dp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="top|start"
                        android:hint="@string/notes_placeholder"
                        android:imeOptions="flagNoExtractUi"
                        android:inputType="textCapSentences|textMultiLine|textAutoCorrect"
                        android:lineSpacingExtra="10dp"
                        android:minHeight="420dp"
                        android:paddingStart="24dp"
                        android:paddingTop="28dp"
                        android:paddingEnd="24dp"
                        android:paddingBottom="28dp"
                        android:textColor="#FF4A3A14"
                        android:textColorHint="#99725621"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/notes_save_button"
                            android:layout_width="0dp"
                            android:layout_height="92dp"
                            android:layout_marginEnd="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_save_button"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="@string/notes_save"
                            android:textColor="@color/white"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/notes_close_button"
                            android:layout_width="0dp"
                            android:layout_height="92dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_close_button"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="@string/notes_close"
                            android:textColor="@color/white"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <TextView
        android:id="@+id/notes_app_close_button"
        android:layout_width="260dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_close_button"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="@string/utilities_close_button"
        android:textColor="@color/white"
        android:textSize="34sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/notes_keyboard_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="18dp"
        android:orientation="vertical"
        android:visibility="gone" />

    <include layout="@layout/view_volume_overlay" />

</FrameLayout>
