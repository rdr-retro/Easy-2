<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/utilities_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="32dp"
        android:paddingEnd="24dp">

        <TextView
            android:id="@+id/utilities_title_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/utilities_screen_title"
            android:textColor="@color/black"
            android:textSize="34sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <FrameLayout
                        android:id="@+id/utility_calendar_circle"
                        android:layout_width="154dp"
                        android:layout_height="154dp"
                        android:background="@drawable/bg_contact_avatar_placeholder">

                        <ImageView
                            android:layout_width="78dp"
                            android:layout_height="78dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/utility_calendar"
                            android:src="@drawable/ic_calendar" />

                    </FrameLayout>

                    <TextView
                        android:id="@+id/utility_calendar_label"
                        android:layout_width="154dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_contact_name_chip"
                        android:gravity="center"
                        android:maxLines="1"
                        android:paddingStart="16dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="6dp"
                        android:text="@string/utility_calendar"
                        android:textAlignment="center"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <FrameLayout
                        android:id="@+id/utility_note_circle"
                        android:layout_width="154dp"
                        android:layout_height="154dp"
                        android:background="@drawable/bg_contact_avatar_placeholder">

                        <ImageView
                            android:layout_width="78dp"
                            android:layout_height="78dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/utility_note"
                            android:src="@drawable/ic_note" />

                    </FrameLayout>

                    <TextView
                        android:id="@+id/utility_note_label"
                        android:layout_width="154dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_contact_name_chip"
                        android:gravity="center"
                        android:maxLines="1"
                        android:paddingStart="16dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="6dp"
                        android:text="@string/utility_note"
                        android:textAlignment="center"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <FrameLayout
                        android:id="@+id/utility_scan_food_circle"
                        android:layout_width="154dp"
                        android:layout_height="154dp"
                        android:background="@drawable/bg_contact_avatar_placeholder">

                        <ImageView
                            android:layout_width="78dp"
                            android:layout_height="78dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/utility_scan_food"
                            android:src="@drawable/ic_barcode" />

                    </FrameLayout>

                    <TextView
                        android:id="@+id/utility_scan_food_label"
                        android:layout_width="154dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_contact_name_chip"
                        android:gravity="center"
                        android:maxLines="1"
                        android:paddingStart="16dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="6dp"
                        android:text="@string/utility_scan_food"
                        android:textAlignment="center"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <FrameLayout
                        android:id="@+id/utility_hearing_circle"
                        android:layout_width="154dp"
                        android:layout_height="154dp"
                        android:background="@drawable/bg_contact_avatar_placeholder">

                        <ImageView
                            android:layout_width="78dp"
                            android:layout_height="78dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/utility_hearing_assist"
                            android:src="@drawable/ic_ear" />

                    </FrameLayout>

                    <TextView
                        android:id="@+id/utility_hearing_label"
                        android:layout_width="154dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_contact_name_chip"
                        android:gravity="center"
                        android:maxLines="1"
                        android:paddingStart="16dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="6dp"
                        android:text="@string/utility_hearing_assist"
                        android:textAlignment="center"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <FrameLayout
                        android:id="@+id/utility_alarm_circle"
                        android:layout_width="154dp"
                        android:layout_height="154dp"
                        android:background="@drawable/bg_contact_avatar_placeholder">

                        <ImageView
                            android:layout_width="78dp"
                            android:layout_height="78dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/utility_alarm"
                            android:src="@drawable/ic_alarm" />

                    </FrameLayout>

                    <TextView
                        android:id="@+id/utility_alarm_label"
                        android:layout_width="154dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_contact_name_chip"
                        android:gravity="center"
                        android:maxLines="1"
                        android:paddingStart="16dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="6dp"
                        android:text="@string/utility_alarm"
                        android:textAlignment="center"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/close_utilities_button"
        android:layout_width="260dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_close_button"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="@string/utilities_close_button"
        android:textColor="@color/white"
        android:textSize="34sp"
        android:textStyle="bold" />

    <include layout="@layout/view_volume_overlay" />

</FrameLayout>
