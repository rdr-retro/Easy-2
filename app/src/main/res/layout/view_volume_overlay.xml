<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/volume_overlay_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#26000000"
    android:clickable="false"
    android:focusable="false"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/volume_overlay_pill"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_gravity="center"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_volume_overlay_pill"
        android:elevation="18dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="26dp"
        android:paddingTop="26dp"
        android:paddingEnd="26dp"
        android:paddingBottom="26dp">

        <ImageView
            android:id="@+id/volume_overlay_icon"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:contentDescription="@string/volume_overlay_label"
            android:src="@drawable/ic_volume_overlay"
            android:tint="@color/launcher_green" />

        <TextView
            android:id="@+id/volume_overlay_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/volume_overlay_default"
            android:textColor="@color/launcher_green"
            android:textSize="54sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/volume_overlay_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/volume_overlay_label"
            android:textColor="@color/launcher_green"
            android:textSize="24sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/volume_overlay_track"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_volume_overlay_track">

            <View
                android:id="@+id/volume_overlay_fill"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_volume_overlay_fill" />

        </FrameLayout>

    </LinearLayout>

</FrameLayout>
