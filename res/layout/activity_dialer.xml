<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialer_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="28dp"
        android:paddingEnd="24dp"
        android:paddingBottom="148dp">

        <TextView
            android:id="@+id/dialer_title_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dialer_title"
            android:textColor="@color/black"
            android:textSize="34sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/dialer_display_card"
            android:layout_width="match_parent"
            android:layout_height="116dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_setup_field"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/dialer_number_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:textColor="@color/black"
                android:textSize="38sp"
                android:textStyle="bold" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dialer_digit_1"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialer_digit_2"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginStart="14dp"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialer_digit_3"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginStart="14dp"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dialer_digit_4"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:gravity="center"
                android:text="4"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialer_digit_5"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginStart="14dp"
                android:gravity="center"
                android:text="5"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialer_digit_6"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginStart="14dp"
                android:gravity="center"
                android:text="6"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dialer_digit_7"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:gravity="center"
                android:text="7"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialer_digit_8"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginStart="14dp"
                android:gravity="center"
                android:text="8"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialer_digit_9"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginStart="14dp"
                android:gravity="center"
                android:text="9"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dialer_digit_star"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:gravity="center"
                android:text="*"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialer_digit_0"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginStart="14dp"
                android:gravity="center"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialer_digit_hash"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginStart="14dp"
                android:gravity="center"
                android:text="#"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dialer_delete_button"
                android:layout_width="0dp"
                android:layout_height="76dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/dialer_delete"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialer_call_button"
                android:layout_width="0dp"
                android:layout_height="76dp"
                android:layout_marginStart="14dp"
                android:layout_weight="1.3"
                android:gravity="center"
                android:text="@string/dialer_call"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/close_dialer_button"
        android:layout_width="260dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_close_button"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="@string/utilities_close_button"
        android:textColor="@color/white"
        android:textSize="34sp"
        android:textStyle="bold" />

    <include layout="@layout/view_volume_overlay" />

</FrameLayout>
