<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/hearing_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="32dp"
            android:paddingEnd="24dp"
            android:paddingBottom="152dp">

            <TextView
                android:id="@+id/hearing_title_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hearing_screen_title"
                android:textColor="@color/black"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/hearing_subtitle_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/hearing_screen_subtitle"
                android:textColor="@color/black"
                android:textSize="22sp" />

            <LinearLayout
                android:id="@+id/hearing_status_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:id="@+id/hearing_status_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/hearing_status_title_waiting_headphones"
                    android:textColor="@color/black"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/hearing_status_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/hearing_status_detail_waiting_headphones"
                    android:textColor="@color/black"
                    android:textSize="21sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/hearing_note_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/hearing_note"
                android:textColor="@color/black"
                android:textSize="19sp" />

            <TextView
                android:id="@+id/hearing_amplifier_button"
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="@string/hearing_start_now"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/hearing_sound_button"
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/hearing_open_sound_settings"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/hearing_devices_button"
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/hearing_open_hearing_devices"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/hearing_accessibility_button"
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/hearing_open_amplifier"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

        </LinearLayout>

    </ScrollView>

    <TextView
        android:id="@+id/close_hearing_button"
        android:layout_width="260dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_close_button"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="@string/hearing_back"
        android:textColor="@color/white"
        android:textSize="34sp"
        android:textStyle="bold" />

    <include layout="@layout/view_volume_overlay" />

</FrameLayout>
