<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/keyboard_activation_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="32dp"
        android:paddingEnd="24dp"
        android:paddingBottom="144dp">

        <TextView
            android:id="@+id/keyboard_activation_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/keyboard_activation_title"
            android:textColor="@color/black"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/keyboard_activation_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/keyboard_activation_detail"
            android:textColor="@color/black"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/keyboard_activation_settings_button"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_marginTop="26dp"
            android:background="@drawable/bg_save_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/keyboard_open_system_settings"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/keyboard_activation_picker_button"
            android:layout_width="match_parent"
            android:layout_height="92dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_save_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/keyboard_open_picker"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:id="@+id/keyboard_activation_close_button"
        android:layout_width="260dp"
        android:layout_height="96dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_close_button"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="@string/utilities_close_button"
        android:textColor="@color/white"
        android:textSize="34sp"
        android:textStyle="bold" />

</FrameLayout>
